# =============================================================================
# PoggioAI/MSc LLM Configuration — Example / Safe Defaults
# =============================================================================
# Copy this file to .llm_config.yaml and customize:
#   cp .llm_config.yaml.example .llm_config.yaml
#
# .llm_config.yaml is gitignored — your local copy won't be committed.

# --- Main model for all agents ---
main_agents:
  model: claude-sonnet-4-6           # cheaper default; use claude-opus-4-6 for best quality
  reasoning_effort: high
  budget_tokens: 128000

# --- Experiment tool models (AI-Scientist-v2 integration) ---
run_experiment_tool:
  code_model: claude-sonnet-4-6
  feedback_model: claude-sonnet-4-6
  vlm_model: claude-sonnet-4-6
  report_model: claude-sonnet-4-6

# --- Budget enforcement ---
budget:
  usd_limit: 25                      # safe exploration budget; increase for production
  hard_stop: true                    # halt pipeline when limit reached
  fail_closed: true                  # treat corrupted state as over-budget (safe default)
  pricing:
    claude-opus-4-6:
      input_per_1k: 0.005
      output_per_1k: 0.025
    claude-sonnet-4-6:
      input_per_1k: 0.003
      output_per_1k: 0.015
    claude-sonnet-4-5:
      input_per_1k: 0.003
      output_per_1k: 0.015
    gpt-5:
      input_per_1k: 0.002
      output_per_1k: 0.012
    gpt-5.4:
      input_per_1k: 0.0025
      output_per_1k: 0.015
    gemini-3-pro-preview:
      input_per_1k: 0.00125
      output_per_1k: 0.01

# --- Multi-model counsel (debate) ---
# Requires API keys for ALL listed providers. Disabled by default.
counsel:
  enabled: false                     # set true + add all API keys to enable
  max_debate_rounds: 3
  synthesis_model: claude-sonnet-4-6
  models:
  - model: claude-sonnet-4-6
    reasoning_effort: high
  - model: gpt-5.4
    reasoning_effort: high
    verbosity: high
  - model: gemini-3-pro-preview
    thinking_budget: 131072

# --- Persona council (V2 pipeline) ---
persona_council:
  max_debate_rounds: 3
  synthesis_model: claude-sonnet-4-6

# --- Duality check model ---
duality_check:
  model: claude-sonnet-4-6

# --- Per-agent model tiers (optional optimization) ---
# When enabled, assigns cheaper models to simpler agents.
# Disabled by default — all agents use the main model.
per_agent_models:
  enabled: false
  tiers:
    opus:
      model: claude-opus-4-6
      reasoning_effort: high
      budget_tokens: 128000
    sonnet:
      model: claude-sonnet-4-6
      reasoning_effort: high
      budget_tokens: 128000
    economy:
      model: claude-sonnet-4-6
      reasoning_effort: low
  agent_tiers:
    literature_review_agent: sonnet
    math_literature_agent: sonnet
    experiment_literature_agent: sonnet
    math_empirical_verifier_agent: sonnet
    formalize_results_agent: sonnet
    writeup_agent: sonnet
    reviewer_agent: sonnet
    experimentation_agent: sonnet
    followup_lit_review: sonnet
    proofreading_agent: economy
    proof_transcription_agent: economy
    experiment_transcription_agent: economy
    resource_preparation_agent: economy
