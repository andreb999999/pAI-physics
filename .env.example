# =============================================================================
# PoggioAI/MSc Environment Variables
# =============================================================================
# Copy this file to .env and fill in at least one API key:
#   cp .env.example .env
#
# .env is gitignored — your local copy won't be committed.

# --- LLM Provider API Keys (at least one required) ---
OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# GOOGLE_API_KEY=your_google_api_key_here
# OPENROUTER_API_KEY=your_openrouter_api_key_here
# DEEPSEEK_API_KEY=your_deepseek_api_key_here
# XAI_API_KEY=your_xai_api_key_here

# --- Search / Web Tools (optional) ---
# SERPER_API_KEY=your_serper_api_key_here
# SEARXNG_INSTANCE_URL=https://your-searxng-instance

# --- Tinker Mode (GPU training via Tinker API) ---
# TINKER_API_KEY=your_tinker_api_key_here
